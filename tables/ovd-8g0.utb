#+language: ovd
#+type: computer
#+contraction: no
#+grade: 0
#+dots: 8
#+direction: both

lowercase ð 1456
uppercase Ð 14567
uppercase Ą 1267
lowercase ą 126
always ą̊ 12356
always \x00c5\x0328 123567
uppercase Ę 1567
lowercase ę 156
uppercase Į 357
lowercase į 35
uppercase Ų 3467
lowercase ų 346
always \x0079\x0328 12346
always Y̨ 123467

include sv-8g0s.utb

