include braille-patterns.cti

# To ensure punctuation back-translated properly
prepunc \x201C 236
postpunc \x201D 356
postpunc .] 256-2356-3
noback prepunc ' 6-236
prepunc ‘ 6-236
noback postpunc ' 356-3
postpunc ’ 356-3


letter \x0901 3 # devanagari chandra bindu 
letter \x0902 56 # devanagari anuswar 
letter \x0903 6 # devanagari visarg

letter \x0905 1 #"a"
letter \x0906 345 #baraa aa"
letter \x0907 24 #"chhoTi ii"
letter \x0908 35 #"baRii ii"
letter \x0909 136 #"chhoTaa u"
letter \x090A 1256 #"baRaa uu"
noback letter \x090B 5-1235 #"RRi" - need noback because multicell
noback letter \x090C 5-123 #"lri" - need noback because multicell
noback letter \x090D 34 #"Candra e" - not in Bharti 2.1 doc
noback letter \x090E 26 #"short e for dravidian" - not in Bharti 2.1 doc
letter \x090F 15 #"e"
letter \x0910 34 #"ai"
letter \x0911 1346 #"o as in office"
noback letter \x0912 1346 #"short o" - not often in Hindi
letter \x0913 135 #"o"
letter \x0914 246 #"au"

replace \x200D  

letter \x0915 13 # devanagari ka
letter \x0916 46 # devanagari kha
letter \x0917 1245 # devanagari ga
letter \x0918 126 # devanagari gha
letter \x0919 346 #devanagari aNgaa

letter \x091A 14 # devanagari cha
letter \x091B 16 # devanagari cha
letter \x091C 245 # devanagari ja
letter \x091D 356 # devanagari jha
letter \x091E 25 #devanagari yangaa

letter \x091F 23456 # devanagari ta
letter \x0920 2456 # devanagari tha
letter \x0921 1246 # devanagari da
letter \x0922 123456 # devanagari dha
letter \x0923 3456 #devanagari nna

letter \x0924 2345 # devanagari ta
letter \x0925 1456 # devanagari tha
letter \x0926 145 # devanagari da
letter \x0927 2346 # devanagari dha
letter \x0928 1345 #devanagari na

letter \x0929 5-1345 #devanagari na nukta

letter \x092A 1234 # devanagari pa
letter \x092B 124 # devanagari pha
letter \x092C 12 # devanagari ba
letter \x092D 45 # devanagari bha
letter \x092E 134 #devanagari ma

letter \x092F 13456 # devanagari yaa
letter \x0930 1235 # devanagari ra
noback letter \x0931 5-1235 # devanagari rra - not often used in Hindi
letter \x0932 123 # devanagari la
letter \x0933 456 #devanagari la
noback letter \x0934 5-12356 #devanagari la - not often used in Hindi
letter \x0935 1236 #devanagari va
letter \x0936 146 #devanagari sha
letter \x0937 12346 #devanagari ssha
letter \x0938 234 #devanagari sa
letter \x0939 125 #devanagari ha

letter \x093c 5 #devanagari Nukhta
letter \x093d 2 #devanagari avagrah

#--------
# matras

letter \x093E 345 #baraa aa ki matra
letter \x093F 24 #"chhoTi ii matra
letter \x0940 35 #"baRii ii matra
letter \x0941 136 #chhoTaa u matra
letter \x0942 1256 #"baRaa uu matra"
letter \x0943 5-1235 #"RRi matra"
letter \x0944 6-1235 #"lri matra"
noback letter \x0945 1346 #"e matra" - not often used in Hindi
letter \x0946 26 #"ai matra"
letter \x0947 15 #"e matra"
letter \x0948 34 #"ai matra"
letter \x0949 1346 #"o"
letter \x094A 1346 #"au"
letter \x094B 135 #"o matra"
letter \x094C 246 #"au matra"

letter \x094D 4 # Halant
letter \x0950 5-1256 #"devanagari sign for om"
letter \x1CDA 1356 #"strress sign swarita used in vedic text"
noback letter \x0951 1356 #"stress sign Uddatta used in vedic text" - not often used in Hindi
letter \x0952 12356 #"strress sign Anudatta used in vedic text"

letter \x0960 6-1235 #"vocalic rr"
letter \x0961 6-123 #"vocalic lla"
letter \x0962 5-123 #"vocalic la"
letter \x0963 6-123 #"vocalic ll"

#Nukhta

letter \x0958 5-13 #"Ka with Nukhta"
letter \x0959 5-46 #"kha with nukhta"
letter \x095A 5-1245 #"ga with nukhta"
letter \x095B 5-245 #"ja with nukhta"
letter \x095C 12456 #"da with nukhta"
letter \x095D 5-12456 #"dhaa with nukhta"
letter \x095E 5-124 #"fa with nukhta"
letter \x095F 5-13456 #"ya with nukhta"

always \x0915\x093C 5-13 #"ka with nukhta"
always \x0916\x093C 5-46 #"kha with nukhta"
always \x0917\x093C 5-1245 #"ga with nukhta"
always \x091c\x093C 5-245 #"ja with nukhta"
always \x0921\x093C 12456 #"da with nukhta"
always \x0922\x093C 5-12456 #"dhaa with nukhta"
always \x092B\x093C 5-124 #"fa with nukhta"
always \x092F\x093C 5-13456 #"ya with nukhta"

# poorn Viram and double poorn Viraam
punctuation \x0964 256 # "Poorn Viraam"
punctuation \x0965 256-256 # "Double Poorn Viraam"
punctuation \x0970 256 # "abbreviation sign"

# 3456 is letter 'NNA' and the number sign.
nofor midendword \x0923 3456 # Devanagari LETTER NNA

#--------
# digits

litdigit \x0966 245 # devanagari 0
litdigit \x0967 1 # devanagari 1
litdigit \x0968 12 # devanagari 2
litdigit \x0969 14 # devanagari 3
litdigit \x096A 145 # devanagari 4
litdigit \x096B 15 # devanagari 5
litdigit \x096C 124 # devanagari 6
litdigit \x096D 1245 # devanagari 7
litdigit \x096E 125 # devanagari 8
litdigit \x096F 24 # devanagari 9

digit \x0966 245 # devanagari 0
digit \x0967 1 # devanagari 1
digit \x0968 12 # devanagari 2
digit \x0969 14 # devanagari 3
digit \x096A 145 # devanagari 4
digit \x096B 15 # devanagari 5
digit \x096C 124 # devanagari 6
digit \x096D 1245 # devanagari 7
digit \x096E 125 # devanagari 8
digit \x096F 24 # devanagari 9

# ksha and gya

always \x0915\x094D\x0937\x094D 4-12345 #"ksha"
always \x091C\x094D\x091E 156 #"gyan"
always \x0915\x094D\x0937  12345 #"ksha"


