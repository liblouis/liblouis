#------------

attribute ConsonantLetter \x0915\x0916\x0917\x0918\x0919\x091A\x091B\x091C\x091D\x091E\x091F\x0920\x0921\x0922\x0923\x0924\x0925\x0926\x0927\x0928\x092A\x092B\x092C\x092D\x092E\x092F\x0930\x0931\x0932\x0933\x0934\x0935\x0936\x0937\x0938\x0939\x093C

attribute DevanagariCharacters \x0902\x0906\x0907\x0908\x0909\x090A\x090D\x090E\x090F\x0910\x0911\x0912\x0913\x0914\x093E\x093F\x0940\x0941\x0942\x0943\x0944\x0945\x0946\x0947\x0948\x0949\x094A\x094B\x094C\x0915\x0916\x0917\x0918\x0919\x091A\x091B\x091C\x091D\x091E\x091F\x0920\x0921\x0922\x0923\x0924\x0925\x0926\x0927\x0928\x092A\x092B\x092C\x092D\x092E\x092F\x0930\x0931\x0932\x0933\x0934\x0935\x0936\x0937\x0938\x0939\x093C\x0964\x0965


# consonent followed by vowel but not matra
after ConsonantLetter always \x0906 1-345 #"baraa aa"
after ConsonantLetter always \x0907 1-24 #"chhoTi ii"
after ConsonantLetter always \x0908 1-35 #"baRii ii"
after ConsonantLetter always \x0909 1-136 #"chhoTaa u"
after ConsonantLetter always \x090A 1-1256 #"baRaa uu"
after ConsonantLetter always \x090B 1-5-1235 #"RRi"
after ConsonantLetter always \x090C 1-5-123 #"lri"
noback after ConsonantLetter always \x090D 1-34 #"Candra e" - not in Bharti 2.1 doc
noback after ConsonantLetter always \x090E 1-26 #"short e for dravidian" - not in Bharti 2.1 doc
after ConsonantLetter always \x090F 1-15 #"e"
after ConsonantLetter always \x0910 1-34 #"ai"
after ConsonantLetter always \x0911 1-1346 #"o as in office"
noback after ConsonantLetter always \x0912 1-1346 #"short o" - not often in Hindi
after ConsonantLetter always \x0913 1-135 #"o"
after ConsonantLetter always \x0914 1-246 #"au"

# Vowels in backtranslation
# For back translation, vowel after consonant is matra
after ConsonantLetter always \x093E 345 #baraa aa ki matra
after ConsonantLetter always \x093F 24 #"chhoTi ii matra
after ConsonantLetter always \x0940 35 #"baRii ii matra
after ConsonantLetter always \x0941 136 #chhoTaa u matra
after ConsonantLetter always \x0942 1256 #"baRaa uu matra"
after ConsonantLetter always \x0943 5-1235 #"RRi matra"
after ConsonantLetter always \x0944 6-1235 #"lri matra"
after ConsonantLetter always \x0946 26 #"ai matra"
after ConsonantLetter always \x0947 15 #"e matra"
after ConsonantLetter always \x0948 34 #"ai matra"
after ConsonantLetter always \x0949 1346 #"o"
after ConsonantLetter always \x094B 135 #"o matra"
after ConsonantLetter always \x094C 246 #"au matra"

#for back translation of poornViram or Devanagari danda. dot 256 after Devanagari characters will be Danda and not dot.

after DevanagariCharacters always \x0964 256 # Devanagari Danda/Poornviram

# Following needed in backtranslation to override rules in tables which may be included with this table
always \x092D\x0930  45-1235  # BHA + RA - needed to override ® in en-in-g1.ctb table
always \x0916    46    # KHA - needed to override . (period) in en-in-g1.ctb table
always \x091D    356    # JHA - needed to override " (close quotes) in en-in-g1.ctb table
always \x0916\x002C   46-2  # needed to override > (less-than sign) in en-in-g1.ctb table
always \x0916\x092E   46-134  # needed to override µ (micro sign) in en-in-g1.ctb table
always \x0916\x0915   46-13 # to override = (equals sign) in en-in-g1.ctb table
punctuation \x2019 356-3 # to override noback prefix in en-chardefs.cti table
punctuation \x2018 6-236 #  to override noback prefix in en-chardefs.cti table
punctuation ! 235 # to override digit 6 in loweredDigits6Dots.uti table
