lowercase \x0430 1e	       # а CYRILLIC SMALL LETTER A
lowercase \x0431 12e	       # б CYRILLIC SMALL LETTER BE
lowercase \x0432 2456e	       # в CYRILLIC SMALL LETTER VE
lowercase \x0433 1245e	       # г CYRILLIC SMALL LETTER GHE
lowercase \x0434 145e	       # д CYRILLIC SMALL LETTER DE
lowercase \x0435 15e	       # е CYRILLIC SMALL LETTER IE
lowercase \x0451 16e	       # ё CYRILLIC SMALL LETTER IO
lowercase \x0436 245e	       # ж CYRILLIC SMALL LETTER ZHE
lowercase \x0437 1356e	       # з CYRILLIC SMALL LETTER ZE
lowercase \x0438 24e	       # и CYRILLIC SMALL LETTER I
lowercase \x0439 12346e	       # й CYRILLIC SMALL LETTER SHORT I
lowercase \x043a 13e	       # к CYRILLIC SMALL LETTER KA
lowercase \x043b 123e	       # л CYRILLIC SMALL LETTER EL
lowercase \x043c 134e 	       # м CYRILLIC SMALL LETTER EM
lowercase \x043d 1345e	       # н CYRILLIC SMALL LETTER EN
lowercase \x043e 135e	       # о CYRILLIC SMALL LETTER O
lowercase \x043f 1234e	       # п CYRILLIC SMALL LETTER PE
lowercase \x0440 1235e	       # р CYRILLIC SMALL LETTER ER
lowercase \x0441 234e	       # с CYRILLIC SMALL LETTER ES
lowercase \x0442 2345e	       # т CYRILLIC SMALL LETTER TE
lowercase \x0443 136e	       # у CYRILLIC SMALL LETTER U
lowercase \x0444 124e	       # ф CYRILLIC SMALL LETTER EF
lowercase \x0445 125e	       # х CYRILLIC SMALL LETTER HA
lowercase \x0446 14e	       # ц CYRILLIC SMALL LETTER TSE
lowercase \x0447 12345e	       # ч CYRILLIC SMALL LETTER CHE
lowercase \x0448 156e	       # ш CYRILLIC SMALL LETTER SHA
lowercase \x0449 1346e	       # щ CYRILLIC SMALL LETTER SHCHA
lowercase \x044a 12356e	       # ъ CYRILLIC SMALL LETTER HARD SIGN
lowercase \x044b 2346e	       # ы CYRILLIC SMALL LETTER YERU
lowercase \x044c 23456e	       # ь CYRILLIC SMALL LETTER SOFT SIGN
lowercase \x044d 246e	       # э CYRILLIC SMALL LETTER E
lowercase \x044e 1256e	       # ю CYRILLIC SMALL LETTER YU
lowercase \x044f 1246e	       # я CYRILLIC SMALL LETTER YA

# upper case
base uppercase \x0410 \x0430   # А CYRILLIC CAPITAL LETTER A
uppercase А 1ef
base uppercase \x0411 \x0431   # Б CYRILLIC CAPITAL LETTER BE
uppercase Б 12ef
base uppercase \x0412 \x0432   # В CYRILLIC CAPITAL LETTER VE
uppercase В 2456ef
base uppercase \x0413 \x0433   # Г CYRILLIC CAPITAL LETTER GHE
uppercase Г 1245ef
base uppercase \x0414 \x0434   # Д CYRILLIC CAPITAL LETTER DE
uppercase Д 145ef
base uppercase \x0415 \x0435   # Е CYRILLIC CAPITAL LETTER IE
uppercase Е 15ef
base uppercase \x0401 \x0451   # Ё CYRILLIC CAPITAL LETTER IO
uppercase Ё 16ef
base uppercase \x0416 \x0436   # Ж CYRILLIC CAPITAL LETTER ZHE
uppercase Ж 245ef
base uppercase \x0417 \x0437   # З CYRILLIC CAPITAL LETTER ZE
uppercase З 1356ef
base uppercase \x0418 \x0438   # И CYRILLIC CAPITAL LETTER I
uppercase И 24ef
base uppercase \x0419 \x0439   # Й CYRILLIC CAPITAL LETTER SHORT I
uppercase Й 12346ef
base uppercase \x041a \x043a   # К CYRILLIC CAPITAL LETTER KA
uppercase К 13ef
