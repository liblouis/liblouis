lowercase \x00F3 1456b         # DEC 243 ó
base uppercase Ó ó
uppercase Ó 1456bf
noback lowercase \x00F4 4-135b        # DEC 244 ô

undefined 0                   # sign used for undefined characters

# no space within mixed numbers like 1 1/2
# the swapcd rule is for compensating that the litdigit rule is not matched anymore
swapcd aslitdigit 1234567890 19,129,149,1459,159,1249,12459,1259,249,2459 # as defined in litdigits6Dots.uti
noback context [%aslitdigit$s.]$d."/"$d %aslitdigit@3456

# arrows
sign → 25a-5b # rightwards arrow x2192
nofor sign → 25a-5
sign ← 2a-25a # leftwards arrow x2190
nofor sign ← 2-25
sign ↔ 2a-25a-5b # Left right arrow x2194
nofor sign ↔ 2-25-5

# Diacritic characters

include no-no-latinLetterDef6Dots_diacritics.uti
