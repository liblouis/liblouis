space \t 9                   # tab x0009
space \x001b 1b              # escape character for html back-translation # dec 27
space \x00A0 a               # NO-BREAK SPACE <noBreak> 0020 NON-BREAKING SPACE # dec 160
include spaces.uti

include digits8Dots.uti
include latinLetterDef6Dots.uti

noback uppercase A 1f
noback uppercase B 12f
noback uppercase C 14f
noback uppercase D 145f
noback uppercase E 15f
noback uppercase F 124f
noback uppercase G 1245f
noback uppercase H 125f
noback uppercase I 24f
noback uppercase J 245f
noback uppercase K 13f
noback uppercase L 123f
noback uppercase M 134f
noback uppercase N 1345f
noback uppercase O 135f
noback uppercase P 1234f
noback uppercase Q 12345f
noback uppercase R 1235f
noback uppercase S 234f
noback uppercase T 2345f
noback uppercase U 136f
noback uppercase V 1236f
noback uppercase W 2456f
noback uppercase X 1346f
noback uppercase Y 13456f
noback uppercase Z 1356f

punctuation ! 235a            # exclamation mark x0021
nofor postpunc ! 235
punctuation " 256            # double quote x0022
punctuation ' 5              # apostrophe x0027
punctuation ( 236            # left parenthesis x0028
punctuation ) 356            # right parenthesis x0029
punctuation , 2              # coma x002C
punctuation . 3              # point x002E
punctuation : 25             # colon x003A
punctuation ; 23             # semicolon x003B
punctuation ? 26             # question mark x003F
punctuation [ 12356          # left square bracket x005B
punctuation ] 23456          # right square bracket x005D
punctuation { 6-12356c        # left curly bracket x007B
nofor punctuation { 6-12356
punctuation } 6-23456c        # right curly bracket x007D
nofor punctuation } 6-23456
punctuation « 256            # left-pointing double angle quotation mark x00AB
punctuation » 256            # right-pointing double angle quotation mark x00BB
noback punctuation \x2010 36        # 8208 hyphen
noback punctuation \x2011 36        # 8209 non-breaking hyphen
noback punctuation \x2012 36        # figure dash
punctuation \x2013 36-36     # en dash
punctuation \x2014 36-36     # em dash
punctuation \x002D 36        # hyphen-minus x002D
punctuation \x2018 5         # 8216 smart single left quotation mark
punctuation \x2019 5         # 8217 smart single right quotation mark
punctuation \x201C 256       # 8220 smart opening double quote
punctuation \x201D 256       # 8221 smart closing double quote
punctuation \x201E 256       # 8222 smart double low quotation mark
punctuation \x201F 256       # 8223 smart double high reverse quotation mark
punctuation \x2026 3-3-3     # 8230 smart ellipsis
punctuation \x2212 36        # 8722 minus sign

sign # 3456a                  # number sign x0023
sign $ 256a                   # dollar sign x0024
sign £ 123a                   # pound sign
sign % 46-356b                # percent sign x0025
noback sign % 46-356
sign ‰ 46-356b-356b            # per mille sign
noback sign ‰ 46-356-356
sign & 346                   # ampersand z0026
sign * 35                    # asterisk x002A
noback sign @ 4a                     # commercial at x0040
nofor sign @ 4
sign \\ 156                  # reverse solidus x005C
sign ^ 46                    # circumflex accent x005E (math power)
sign _ 456a                   # low line x005F
sign ` 45                    # grave accent x0060
sign \x00AF 45               # macron
sign \x0304 45               # combining macron
lowercase \x00E9 123456      # e with acute é 00E9
sign | 123456b                # vertical line x007C
sign ~ 1456                  # tilde x007E
sign \x0080 15-136-1235-135  # Euro sign x0080
noback sign ¢ 4a-14                  # cent sign x00A2
sign £ 45-123a                # pound sign x00A3
nofor sign £ 45-123
sign ¤ 236-134a-356           # currency sign x00A4
nofor sign ¤ 236-134-356
sign ¥ 45-13456              # yen sign x00A5
sign § 346c                   # section sign x00A7
joinnum § 346c
nofor joinnum § 346
joinnum §§ 346c-346c
nofor joinnum §§ 346-346
sign © 236-14-356            # copyright x00A9
sign ® 236-1235a-356          # Registered trademark
nofor sign ® 236-1235-356
sign ™ 236-2345a-356          # Trademark
nofor sign ™ 236-2345-356
sign ° 5b-356a                 # degree sign x00B0
nofor sign ° 5-356
sign ² 46-129a               # superscript 2 sign x00B2
nofor sign ² 46-12
sign ³ 46-149a               # superscript 3 sign x00B3
nofor sign ³ 46-14
noback sign \x00B4 4a                # acute sign dec-180
sign ¹ 1-27                  # superscript 1 sign x00B9
sign \x20AC 26a               # Euro sign x0080
sign ■ 123456                # Filled square
sign □ 123456                # Empty square
sign ● 2356a                  # Filled circle
sign ○ 2356a                  # Empty circle
sign • 36-36                  # Bullet
