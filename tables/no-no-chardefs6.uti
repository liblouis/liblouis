math + 235                   # plus x002B
nofor math + 56-235                   # plus x002B
math / 34 solidus            # x002F
#noback math < 246b-3                 # less-than sign x003C
noback math < 126b                 # less-than sign x003C
math = 2356                  # equal sign x003D
#noback math > 135-2                 # greater-than sign x003E
noback math > 345b                 # greater-than sign x003E
math × 3                     # multiplication sign x00D7
math ÷ 25                    # division sign x00F7
math √ 146a                   # root sign

